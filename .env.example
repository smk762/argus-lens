# ── Backend selection ────────────────────────────────────────────────
# Default backend for `argus-lens serve` (hybrid, wd14, florence2, openai,
# openai-compat, ...). Equivalent to `serve --backend`.
ARGUS_BACKEND=hybrid

# ── Cloud backend credentials ────────────────────────────────────────
# Each cloud backend reads its own key; set the one(s) you use.
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
HF_TOKEN=
NVIDIA_API_KEY=

# ── Generic OpenAI-compatible backend (--backend openai-compat) ──────
# Point at any server speaking the OpenAI /chat/completions format:
# Ollama, vLLM, LM Studio, LocalAI, llama.cpp, or a hosted proxy.
# Defaults to Ollama on localhost; pick any vision-capable model.
ARGUS_OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
ARGUS_OPENAI_COMPAT_MODEL=llava
# API key is optional — most local servers don't need one.
ARGUS_OPENAI_COMPAT_API_KEY=

# ── Local model paths ────────────────────────────────────────────────
# WD14 ONNX model directory. If unset, defaults to ~/.cache/wd14_tagger/
# and auto-downloads from HuggingFace on first use.
WD14_MODEL_DIR=/home/smk/.cache/wd14_tagger

# HuggingFace cache directory for transformer models (Florence-2, BLIP-2).
# Defaults to ~/.cache/huggingface if unset. These auto-download on first use.
HF_HOME=/home/smk/.cache/huggingface

# ── Folder browsing (caption page folder picker) ─────────────────────
# Root folder exposed by GET /folders and POST /caption/folder; both are
# confined to this root. Equivalent to `serve --source-root`.
# Unset = folder browsing and folder captioning disabled.
LENS_SOURCE_PATH=/data/images
